{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "talhelper@3.1.5",
    "talosctl@1.11.6",
    "just@latest",
    "kubectl@latest",
    "k9s@latest",
    "kubernetes-helm@latest",
    "yq-go@latest",
    "cilium-cli@latest",
    "fluxcd@latest",
    "sops@latest",
    "kubeseal@latest"
