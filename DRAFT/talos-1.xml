<domain type='kvm'>
  <name>talos-1</name>
  <!-- ... other config omitted for brevity ... -->
  
  <devices>
    <!-- 
      In OVS, all interfaces connect to the SAME bridge (ovs-br0).
      We differentiate networks using <tag id='XX'/>.
    -->

    <!-- Network Interface 1: PXE Boot (Untagged/VLAN 10) -->
    <interface type='bridge'>
      <source bridge='ovs-br0'/>
      <virtualport type='openvswitch'/>
      <tag id='10'/>
      <model type='virtio'/>
    </interface>
    
    <!-- Network Interface 2: VLAN 20 -->
    <interface type='bridge'>
      <source bridge='ovs-br0'/>
      <virtualport type='openvswitch'/>
      <tag id='20'/>
      <model type='virtio'/>
    </interface>
    
    <!-- Network Interface 3: VLAN 30 -->
    <interface type='bridge'>
      <source bridge='ovs-br0'/>
      <virtualport type='openvswitch'/>
      <tag id='30'/>
      <model type='virtio'/>
    </interface>

    <!-- Network Interface 4: VLAN 40 -->
    <interface type='bridge'>
      <source bridge='ovs-br0'/>
      <virtualport type='openvswitch'/>
      <tag id='40'/>
      <model type='virtio'/>
    </interface>
  </devices>
</domain>
