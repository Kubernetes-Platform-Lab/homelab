{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.15.1/.schema/devbox.schema.json",
  "packages": [
    "k9s@0.50.16",
    "kubectl@latest",
    "sops@latest"
  ],
  "shell": {
    "env": {
      "SOPS_AGE_KEY_FILE": "~/.config/sops/age/keys.txt"
    },
    "init_hook": [
      "mkdir -p /dev/shm/pxeboot",
      "sops -d ./kubeconfig.yaml > /dev/shm/pxeboot/kubeconfig.yaml",
      "export KUBECONFIG=/dev/shm/pxeboot/kubeconfig.yaml"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}

