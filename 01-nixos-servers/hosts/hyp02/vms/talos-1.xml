<domain type='kvm'>
  <name>talos-1</name>
  <memory unit='GiB'>14</memory>
  <currentMemory unit='GiB'>14</currentMemory>
  <vcpu placement='static'>4</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
  </os>
  <features>
    <acpi />
    <apic />
  </features>
  <cpu mode='host-passthrough'>
    <topology sockets='1' cores='4' threads='1' />
  </cpu>
  <clock offset='utc'>
    <timer name='rtc' tickpolicy='catchup' />
    <timer name='pit' tickpolicy='delay' />
    <timer name='hpet' present='no' />
  </clock>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>restart</on_crash>
  <devices>
    <emulator>/run/libvirt/nix-emulators/qemu-system-x86_64</emulator>

<!-- CD-ROM iso for installation (AMD64) -->
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw' />
      <source file='/var/lib/libvirt/images/metal-amd64.iso' />
      <target dev='sda' bus='scsi' />
      <readonly />
      <boot order='2' />
      <address type='drive' controller='0' bus='0' target='0' unit='0' />
    </disk>

    <!-- qcow2 disk image for storage -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='writethrough' />
      <source file='/var/lib/libvirt/images/talos-1.qcow2' />
      <target dev='vda' bus='virtio' />
      <boot order='1' />
    </disk>

    <!-- /dev/sda passthru for storage -->
    <disk type='block' device='disk'>
      <source dev='/dev/sda' />
      <target dev='vdb' bus='virtio' />
    </disk>

    <!-- SCSI Controller for CD-ROM -->
    <controller type='scsi' index='0' model='virtio-scsi' />

    <!-- Network Interface 3: VLAN 30 on br-int -->
    <interface type='bridge'>
      <source bridge='br-int' />
      <virtualport type='openvswitch' />
      <vlan>
        <tag id='30' />
      </vlan>
      <model type='virtio' />
      <mac address='06:54:00:12:34:30' />
    </interface>

    <!-- Network Interface 4: VLAN 40 on br-int -->
    <interface type='bridge'>
      <source bridge='br-int' />
      <virtualport type='openvswitch' />
      <vlan>
        <tag id='40' />
      </vlan>
      <model type='virtio' />
      <mac address='06:54:00:12:34:40' />
    </interface>

    <!-- Serial console for remote access -->
    <serial type='pty'>
      <target type='isa-serial' port='0'>
        <model name='isa-serial' />
      </target>
    </serial>
    <console type='pty'>
      <target type='serial' port='0' />
    </console>

  <channel type='unix'>
  <source mode='bind' />
  <target type='virtio' name='org.qemu.guest_agent.0' />
  </channel>

    <!-- Graphics (for virt-manager GUI) -->
    <graphics type='vnc' port='-1' autoport='yes' listen='127.0.0.1'>
      <listen type='address' address='127.0.0.1' />
    </graphics>
    <video>
      <model
                type='qxl'
                ram='65536'
                vram='65536'
                vgamem='16384'
                heads='1'
                primary='yes'
            />
    </video>
  </devices>
</domain>
